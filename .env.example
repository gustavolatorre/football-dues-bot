# ===== Telegram =====
# Token do bot criado no @BotFather (/newbot)
BOT_TOKEN=
# IDs numericos de admin, separados por virgula (descubra no @userinfobot)
ADMIN_IDS=

# ===== Mensalidade =====
MENSALIDADE_VALOR=40.00
# Dia do mes em que a cobranca abre (1-28)
DIA_COBRANCA=10

# ===== Destino esperado do PIX (anti-fraude) =====
# Chave PIX e nome do recebedor que aparecem no comprovante
PIX_DESTINO=+55DDDNUMERO
NOME_RECEBEDOR=Nome do Recebedor

# ===== Banco de dados =====
# Local (dev): SQLite. No Railway, o plugin Postgres injeta DATABASE_URL automaticamente.
DATABASE_URL=sqlite:///data/bot.db

# ===== Operacao =====
TZ=America/Sao_Paulo
RECONCILE_INTERVAL_HORAS=3
OCR_CONFIANCA_MIN=80
# Teto de auto-aprovacao = divida atual + N mensalidades. Acima disso o comprovante
# vai ao admin (evita que um erro de OCR infle o valor). Tambem permite pre-pagar N meses.
MAX_MENSALIDADES_ADIANTADO=3
